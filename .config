CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_BOARD="qualcommax"
CONFIG_TARGET_SUBTARGET="ipq60xx"
CONFIG_TARGET_PROFILE="DEVICE_jdcloud_re-cs-02"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"

# 基础系统配置
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y

# 内核配置
CONFIG_KERNEL_BUILD_USER="fanling1970"
CONFIG_KERNEL_BUILD_DOMAIN="github.com"
CONFIG_KERNEL_KALLSYMS=y
CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_CGROUP_CPUACCT=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_SCHED=y
CONFIG_KERNEL_CPUSETS=y
CONFIG_KERNEL_MEMCG=y
CONFIG_KERNEL_NAMESPACES=y
CONFIG_KERNEL_USER_NS=y
CONFIG_KERNEL_NET_NS=y
CONFIG_KERNEL_IPC_NS=y
CONFIG_KERNEL_UTS_NS=y
CONFIG_KERNEL_PID_NS=y

# Docker相关配置
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker-compose=n
CONFIG_PACKAGE_libnetwork=y
CONFIG_PACKAGE_tini=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y

# Docker依赖
CONFIG_KERNEL_BRIDGE=y
CONFIG_KERNEL_BRIDGE_NETFILTER=y
CONFIG_KERNEL_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_KERNEL_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_KERNEL_NETFILTER_XT_MATCH_IPVS=y
CONFIG_KERNEL_IP_NF_IPTABLES=y
CONFIG_KERNEL_IP_NF_FILTER=y
CONFIG_KERNEL_IP_NF_NAT=y
CONFIG_KERNEL_IP_NF_TARGET_MASQUERADE=y
CONFIG_KERNEL_NETFILTER_XT_TARGET_CHECKSUM=y
CONFIG_KERNEL_CGROUP_BPF=y
CONFIG_KERNEL_BPF=y
CONFIG_KERNEL_BPF_SYSCALL=y
CONFIG_KERNEL_OVERLAY_FS=y
CONFIG_KERNEL_VXLAN=y
CONFIG_KERNEL_NET_IPVTI=y
CONFIG_KERNEL_NET_UDP_TUNNEL=y
CONFIG_KERNEL_IPVLAN=y
CONFIG_KERNEL_MACVLAN=y
CONFIG_KERNEL_DUMMY=y
CONFIG_KERNEL_NF_CONNTRACK=y
CONFIG_KERNEL_NF_NAT=y

# Samba相关配置
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y
CONFIG_PACKAGE_samba4-client=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_SAMBA4_SERVER_AVAHI=y
CONFIG_SAMBA4_SERVER_NETBIOS=y
CONFIG_SAMBA4_SERVER_WSDD2=y

# SSR相关配置（使用Lean源中的标准包）
CONFIG_PACKAGE_shadowsocks-libev-ss-local=y
CONFIG_PACKAGE_shadowsocks-libev-ss-redir=y
CONFIG_PACKAGE_shadowsocks-libev-ss-server=y
CONFIG_PACKAGE_luci-app-shadowsocks=y
CONFIG_PACKAGE_luci-i18n-shadowsocks-zh-cn=y
# 以下包可能在Lean源中不存在，暂时注释掉
# CONFIG_PACKAGE_simple-obfs=y
# CONFIG_PACKAGE_v2ray-plugin=y

# 网络基础
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-iprange=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_conntrack=y

# LuCI界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_LUCI_LANG_zh-cn=y

# 中文支持
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-nls-cp936=y

# 文件系统支持
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_ntfs-3g=y

# USB支持（如果路由器有USB接口）
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_block-mount=y

# 其他实用工具
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_tmux=y

# 编译优化
CONFIG_CCACHE=y
CONFIG_BUILD_LOG=y

# 内存优化（针对3GB内存）
CONFIG_KERNEL_SLUB=y
CONFIG_KERNEL_SLUB_DEBUG=n
CONFIG_KERNEL_SLUB_DEBUG_ON=n

# 网络性能优化
CONFIG_KERNEL_NET_SCHED=y
CONFIG_KERNEL_NET_SCH_SFQ=y
CONFIG_KERNEL_NET_SCH_HTB=y
CONFIG_KERNEL_NET_SCH_CODEL=y
CONFIG_KERNEL_NET_SCH_FQ_CODEL=y

# 文件系统缓存优化
CONFIG_KERNEL_DEVMEM=y
CONFIG_KERNEL_DEVKMEM=y
