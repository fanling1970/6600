config wifi-device 'radio0'
    option type 'mac80211'
    option path 'platform/soc@0/c000000.wifi'
    option band '5g'
    option channel '100'
    option htmode 'HE80'
    option country 'US'
    option disabled '0'

config wifi-iface 'default_radio0'
    option device 'radio0'
    option network 'lan'
    option mode 'ap'
    option ssid 'LEDE_5G'
    option encryption 'psk2+ccmp'
    option key 'YourPasswordHere'
    option disabled '0'

config wifi-device 'radio1'
    option type 'mac80211'
    option path 'platform/soc@0/c000000.wifi+1'
    option band '2g'
    option channel 'auto'
    option htmode 'HE40'
    option country 'US'
    option disabled '0'

config wifi-iface 'default_radio1'
    option device 'radio1'
    option network 'lan'
    option mode 'ap'
    option ssid 'LEDE_2.4G'
    option encryption 'psk2+ccmp'
    option key 'YourPasswordHere'
    option disabled '0'

# ✅ 强制启用 radio2：使用标准PCI路径 + 非DFS信道 + 驱动调试参数
config wifi-device 'radio2'
    option type 'mac80211'
    # ★ 关键：仅保留标准PCI路径，不加 soc/pcie 前缀
    option path 'pci0000:00/0000:00:00.0/0000:01:00.0'
    option band '5g'
    option channel '149'          # 非DFS信道，避免与radio0冲突
    option htmode 'HE80'
    option country 'US'
    option cell_density '0'
    # ★ 新增：强制加载驱动并记录日志
    option noscan '1'
    option beacon_int '100'
    option disabled '0'

config wifi-iface 'default_radio2'
    option device 'radio2'
    option network 'lan'
    option mode 'ap'
    option ssid 'LEDE_5G_Game'
    option encryption 'psk2+ccmp'
    option key 'YourPasswordHere'
    option disabled '0'
