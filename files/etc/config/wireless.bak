config wifi-device 'radio0'
    option type 'mac80211'
    option path 'platform/soc@0/c000000.wifi'
    option band '5g'
    option channel '100'
    option htmode 'HE80'
    option country 'US'
    option disabled '0'

config wifi-iface 'default_radio0'
    option device 'radio0'
    option network 'lan'
    option mode 'ap'
    option ssid 'LEDE_5G'
    option encryption 'psk2+ccmp'
    option key 'YourPasswordHere'
    option disabled '0'

config wifi-device 'radio1'
    option type 'mac80211'
    option path 'platform/soc@0/c000000.wifi+1'
    option band '2g'
    option channel 'auto'
    option htmode 'HE40'
    option country 'US'
    option disabled '0'

config wifi-iface 'default_radio1'
    option device 'radio1'
    option network 'lan'
    option mode 'ap'
    option ssid 'LEDE_2.4G'
    option encryption 'psk2+ccmp'
    option key 'YourPasswordHere'
    option disabled '0'

config wifi-device 'radio2'
    option type 'mac80211'
    option band '5g'
    option htmode 'HE80'
    option channel '36'
    option path 'platform/ahb/18100000.wifi+2'
    option hwmode '11a'
    option disabled '0'

config wifi-iface 'default_radio2'
    option device 'radio2'
    option network 'lan'
    option mode 'ap'
    option ssid 'JDC_AX6600_5G2'
    option encryption 'psk2'
    option key '12345678'
